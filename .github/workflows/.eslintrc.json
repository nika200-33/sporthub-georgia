{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    // production build-ში console.log-ების დავიწყება ხშირი შეცდომაა —
    // ვაძლევთ warning-ს და არა error-ს, რომ console.error/warn დარჩეს
    // თავისუფლად გამოსაყენებელი შეცდომების დასაფიქსირებლად.
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "@typescript-eslint/no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_" }
    ]
  }
}
